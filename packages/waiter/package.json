{
  "name": "jixu",
  "version": "0.1.0",
  "description": "Claude Code 会话自动续接守护进程",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loredunk/jixu.git",
    "directory": "packages/waiter"
  },
  "bin": {
    "jixu": "dist/main.js"
  },
  "main": "dist/main.js",
  "files": [
    "dist",
    "plugin"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@jixu/adapter-claude": "^0.1.0",
    "@jixu/core": "^0.1.0"
  },
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/main.js start",
    "stop": "node dist/main.js stop",
    "status": "node dist/main.js status",
    "bundle-plugin": "node scripts/bundle-plugin.mjs",
    "prepack": "npm run build && npm run bundle-plugin"
  }
}
